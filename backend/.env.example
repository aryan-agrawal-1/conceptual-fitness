GOOGLE_HEALTH_API_TIMEOUT_SECONDS=30
GOOGLE_HEALTH_PAGE_SIZE=500

TOKEN_ENCRYPTION_KEY=
SESSION_SECRET_KEY=

CELERY_TIMEZONE=UTC
CELERY_SYNC_HOUR=*
