APP_ENV=local
APP_BASE_URL=http://localhost:8000
IOS_DEEP_LINK_REDIRECT=healthapp://oauth/google-health

APP_HOST=0.0.0.0
APP_PORT=8000
API_PORT=8000
UVICORN_RELOAD_FLAG=--reload

POSTGRES_DB=health
POSTGRES_USER=health
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://health:change-me@localhost:5432/health
